{
  "include": ["./modules.jsonc"],

  "layer": "top",
  "position": "top",
  "spacing": 0,

  "modules-left": ["custom/logo", "bluetooth", "pulseaudio", "hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["tray", "network", "group/batinfo", "cpu", "memory", "clock"],

// add notifs

  "group/batinfo": {
    "orientation": "inherit",
    "modules": [
      "battery",
      "battery#bat2"
    ]
  }

}

